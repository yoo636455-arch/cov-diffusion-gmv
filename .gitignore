# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Claude Code project settings (not for public repo) ───────────────────────
.claude/

# ── Proprietary / large data (not redistributable; too large for GitHub) ──────
# Raw CRSP daily equity data — 383 MB, requires WRDS subscription
data/raw/
# Cleaned CRSP panel — 372 MB, derived from proprietary raw data
data/interim/cleaned_crsp_daily.parquet

# ── Large processed arrays (313 MB; regenerable by running scripts 01–03) ─────
data/processed/covariance_pairs_train.npz
data/processed/covariance_pairs_train.meta.parquet

# ── Validation / inference cache (regenerable by running script 05) ───────────
results/validation/cache/

# ── Trained model checkpoints (run script 04 to produce for current T grid) ───
artifacts/models/*.pt
